GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=

# URL pública exacta de la app, sin barra final.
# Local: http://localhost:3000
# Producción (ejemplo): https://firmero.redshell.cloud
NEXTAUTH_URL=http://localhost:3000

# Uno o varios correos admin (coma o punto y coma). Mismo dominio que usen con Google.
# Ejemplo: admin@example.com,otro@empresa.com
ADMIN_EMAIL=admin@example.com

# Google Analytics 4 (opcional). Vacío o "false" desactiva. Por defecto en código: G-83MBFMV0X8.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-83MBFMV0X8

# Redis: local / manual (mismo valor que te da Upstash o Vercel Storage)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Si usas la integración "Storage" en Vercel, suelen existir solo estas (la app las lee):
# STORAGE_KV_REST_API_URL=
# STORAGE_KV_REST_API_TOKEN=

KV_URL=
KV_REST_API_READ_ONLY_TOKEN=
